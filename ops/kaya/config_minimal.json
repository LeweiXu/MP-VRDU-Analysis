{
  "ssh_alias": "kaya",
  "remote_root": "/group/ems036/lxu/mpvrdu",
  "python_version": "3.11",
  "modules": [
    {"name": "gcc/9.4.0", "optional": true},
    {"name": "Anaconda3/2024.06", "optional": false},
    {"name": "cuda/12.6.3", "optional": false}
  ],
  "paths": {
    "cache": ".cache",
    "data": ".data",
    "env": "envs/core",
    "results": "results",
    "logs": "logs"
  },
  "pip": {
    "torch_index_url": "https://download.pytorch.org/whl/cu126"
  },
  "hf": {
    "max_workers": 8
  },
  "secrets": {
    "env_file": ".env",
    "forward": ["HF_TOKEN"]
  },
  "slurm": {
    "partition": "gpu",
    "gres": "gpu:1",
    "account": "",
    "qos": "",
    "nodes": 1,
    "ntasks": 1,
    "cpus_per_task": 4,
    "mem": "24G",
    "time": "00:30:00",
    "poll_seconds": 10
  },
  "rsync_excludes": [
    ".git/",
    ".env",
    ".cache/",
    ".data/",
    "envs/",
    "results/",
    "logs/",
    "temp/",
    "__pycache__/",
    "*.pyc"
  ],
  "models": [
    "Qwen/Qwen3-VL-2B-Instruct",
    "Qwen/Qwen3-VL-8B-Instruct"
  ],
  "retrieval_models": {
    "text": [
      "BAAI/bge-m3",
      "Qwen/Qwen3-Embedding-4B"
    ],
    "vision": [
      "ModernVBERT/colmodernvbert",
      "ModernVBERT/colmodernvbert-base",
      "vidore/colqwen2.5-v0.2",
      "vidore/colqwen2.5-base",
      "OpenSearch-AI/Ops-Colqwen3-4B"
    ]
  },
  "retrieval_model_dependencies": {
    "ModernVBERT/colmodernvbert-base": [
      "google/siglip2-base-patch16-512"
    ]
  },
  "parsers": {
    "paddleocrvl": "PaddlePaddle/PaddleOCR-VL"
  },
  "parser_aux_models": {
    "paddleocrvl": ["PaddlePaddle/PP-DocLayoutV2"]
  },
  "datasets": {
    "mmlongbench": "yubo2333/MMLongBench-Doc"
  }
}
